# AI Services
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://your-app.example.com
OPENROUTER_APP_NAME=BizRoom

# Email Services
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_PLAN_ID_MONTHLY=plan_xxx
RAZORPAY_PLAN_ID_QUARTERLY=plan_xxx
RAZORPAY_PLAN_ID_YEARLY=plan_xxx

# Shared secret for the /api/cron/reconcile-subscriptions endpoint - required in the
# `x-cron-secret` header of any request to it (see .github/workflows/reconcile-subscriptions.yml).
# Generate a long random value, e.g. `openssl rand -hex 32`.
CRON_SECRET=your_long_random_cron_secret
