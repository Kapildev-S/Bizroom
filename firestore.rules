
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Billing fields are only ever written by backend code (Admin SDK, which bypasses
    // these rules) after verifying state with Razorpay directly. A client create/update
    // that touches any of these keys is denied even on documents the owner can otherwise
    // write to. `resource` is null on a create (no prior document to diff against), so
    // that case is checked against the new document directly instead of a diff.
    function touchesBillingFields() {
      let billingFields = ['subscriptionStatus', 'premiumExpiry', 'premiumSince', 'subscriptionId', 'lastPaymentId', 'lastPaymentAt', 'lastSyncedAt'];
      return resource == null
        ? request.resource.data.keys().hasAny(billingFields)
        : request.resource.data.diff(resource.data).affectedKeys().hasAny(billingFields);
    }

    match /enclaimUsers/{userId} {
      allow read: if true;
    }

    match /users/{userId}/settings/appSettings {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId && !touchesBillingFields();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/feedback/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && !touchesBillingFields();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Subscription/webhook/reconciliation records - read and written only by backend
    // Admin SDK code (server actions / API routes), never directly by clients.
    match /premium_subscriptions/{subscriptionId} {
      allow read, write: if false;
    }

    match /razorpay_webhook_events/{eventId} {
      allow read, write: if false;
    }

    match /subscription_reconciliation_runs/{runId} {
      allow read, write: if false;
    }

    // Public agent tasks can be read by anyone with the link
    // but only written to by the owner of the original task.
    match /agentTasks/{agentId}/tasks/{taskId} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth == null; // Allow anonymous updates from agents
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid ||
        request.auth.uid == '3l2SpTceF9Qany7x5IRHdHBPU9J3'
      );
    }
  }
}
